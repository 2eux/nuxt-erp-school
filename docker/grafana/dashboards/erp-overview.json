  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "System Health Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-erp" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "text": "UP" }, "0": { "text": "DOWN" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "orientation": "auto", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true, "text": {} },
      "pluginVersion": "11.3.0",
      "targets": [{ "expr": "up{project=\"erp-school\"}", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "Service Status",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-erp" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 4, "y": 1 },
      "id": 2,
      "options": { "orientation": "auto", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "expr": "avg(rate(process_cpu_seconds_total{job=\"backend\"}[5m])) * 100", "legendFormat": "Backend CPU", "refId": "A" },
        { "expr": "avg(rate(process_cpu_seconds_total{job=\"frontend\"}[5m])) * 100", "legendFormat": "Frontend CPU", "refId": "B" }
      ],
      "title": "CPU Usage %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-erp" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 9, "y": 1 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "expr": "(process_resident_memory_bytes{job=\"backend\"} / 1073741824) * 100", "legendFormat": "Backend Memory", "refId": "A" }
      ],
      "title": "Memory Usage %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-erp" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisPlacement": "auto", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5, "spanNulls": false },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 10, "x": 14, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "rate(http_requests_total{job=\"backend\"}[5m])", "legendFormat": "{{method}} {{status}}", "refId": "A" }
      ],
      "title": "API Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
