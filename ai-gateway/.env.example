# =============================================================================
# AI Gateway - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
AI_GATEWAY_ENV=development          # development | production | staging
AI_GATEWAY_PORT=8081                # Server port

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-change-this-in-production
API_KEY=api-key-for-service-accounts
ADMIN_API_KEY=admin-master-key-for-internal-use

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                     # debug | info | warn | error
LOG_FORMAT=json                     # json | console

# -----------------------------------------------------------------------------
# Provider Selection
# -----------------------------------------------------------------------------
DEFAULT_PROVIDER=openai             # openai | gemini | claude | ollama
ENABLED_PROVIDERS=openai,gemini,claude,ollama
FALLBACK_CHAIN=openai,gemini,claude,ollama

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-large
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_RATE_LIMIT=1000
OPENAI_COST_PER_1K_INPUT=0.005
OPENAI_COST_PER_1K_OUTPUT=0.015

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_CHAT=gemini-1.5-pro
GEMINI_MODEL_FAST=gemini-1.5-flash
GEMINI_MODEL_EMBEDDING=text-embedding-004
GEMINI_RATE_LIMIT=1500
GEMINI_COST_PER_1K_INPUT=0.0
GEMINI_COST_PER_1K_OUTPUT=0.0

# -----------------------------------------------------------------------------
# Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_CHAT=claude-3-5-sonnet-20241022
ANTHROPIC_MODEL_BEST=claude-3-opus-20240229
ANTHROPIC_RATE_LIMIT=500
ANTHROPIC_COST_PER_1K_INPUT=0.003
ANTHROPIC_COST_PER_1K_OUTPUT=0.015

# -----------------------------------------------------------------------------
# Ollama (Local LLM)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_CHAT=llama3.1:8b
OLLAMA_MODEL_EMBEDDING=nomic-embed-text
OLLAMA_MODEL_ISLAMIC=hijaz-ai-arabic-llm
OLLAMA_MODEL_QURAN=quran-tafsir-model

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=erp_documents

# -----------------------------------------------------------------------------
# RAG (Retrieval-Augmented Generation)
# -----------------------------------------------------------------------------
RAG_CHUNK_SIZE=1500                # Characters per chunk
RAG_CHUNK_OVERLAP=200              # Overlap between chunks
RAG_TOP_K=5                        # Number of documents to retrieve
RAG_SIMILARITY_THRESHOLD=0.7       # Minimum similarity score (0.0 - 1.0)

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_USER=100            # Requests per window per user
RATE_LIMIT_PER_TENANT=1000         # Requests per window per tenant
RATE_LIMIT_WINDOW_SECONDS=60       # Rate limit window in seconds
