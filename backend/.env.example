# Application
APP_NAME=erp-school
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=erp_school
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=erp-school
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-key-32chars
JWT_REFRESH_SECRET=change-me-refresh-secret-key-32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=erp-school

# AI
AI_PROVIDER=openai
AI_OPENAI_KEY=sk-your-key-here
AI_OPENAI_ENDPOINT=https://api.openai.com/v1
AI_GEMINI_KEY=
AI_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
AI_CLAUDE_KEY=
AI_CLAUDE_ENDPOINT=https://api.anthropic.com/v1
AI_OLLAMA_ENDPOINT=http://localhost:11434
AI_QDRANT_HOST=localhost
AI_QDRANT_PORT=6334
AI_QDRANT_API_KEY=
AI_DEFAULT_MODEL=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_REQUEST_TIMEOUT=60s

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@school.id
SMTP_PASSWORD=
SMTP_FROM=noreply@school.id

# SMS
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# Push Notifications
PUSH_FIREBASE_KEY=

# WhatsApp
WA_API_KEY=
WA_API_SECRET=
WA_PHONE_ID=
WA_BASE_URL=https://graph.facebook.com/v21.0
