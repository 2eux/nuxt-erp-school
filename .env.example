# =============================================================================
# Islamic School ERP - Environment Variables
# =============================================================================
# Copy this file to .env and adjust for your environment.
# NEVER commit the actual .env file to version control.
#
# Generation: openssl rand -hex 32  (for secrets)
# =============================================================================

# -------- Application --------
APP_NAME=erp-school
APP_ENV=production
APP_PORT=8080
APP_DEBUG=false
APP_VERSION=1.0.0

# -------- Domain Configuration --------
DOMAIN=erp-school.id
API_BASE_URL=https://api.erp-school.id
SITE_URL=https://erp-school.id

# -------- Database (PostgreSQL 16) --------
DB_HOST=postgres
DB_PORT=5432
DB_USER=erp_admin
DB_PASSWORD=change_me_in_production
DB_NAME=erp_school
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0
REDIS_POOL_SIZE=20

# -------- MinIO (Object Storage) --------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_pass
MINIO_BUCKET=erp-school
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# -------- JWT Authentication --------
# Generate: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_jwt_access_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_at_least_64_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=erp-school

# -------- AI / LLM Configuration --------
# Supported providers: openai, gemini, claude, ollama, azure
AI_PROVIDER=openai

AI_OPENAI_KEY=sk-your-openai-api-key
AI_OPENAI_ENDPOINT=https://api.openai.com/v1

AI_GEMINI_KEY=your-gemini-api-key
AI_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

AI_CLAUDE_KEY=your-claude-api-key
AI_CLAUDE_ENDPOINT=https://api.anthropic.com/v1

AI_OLLAMA_ENDPOINT=http://ollama:11434

AI_DEFAULT_MODEL=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_REQUEST_TIMEOUT=60s

# -------- Qdrant (Vector Database) --------
AI_QDRANT_HOST=qdrant
AI_QDRANT_PORT=6334
QDRANT_API_KEY=qdrant_dev_key_change_me

# -------- SMTP (Email) --------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@school.id

# -------- SMS (Twilio / custom provider) --------
SMS_PROVIDER=twilio
SMS_API_KEY=your-twilio-account-sid
SMS_API_SECRET=your-twilio-auth-token
SMS_SENDER_ID=ERP-School

# -------- Push Notifications (Firebase) --------
PUSH_FIREBASE_KEY=your-firebase-server-key

# -------- WhatsApp Business API --------
WA_API_KEY=your-whatsapp-api-key
WA_API_SECRET=your-whatsapp-api-secret
WA_PHONE_ID=your-phone-number-id
WA_BASE_URL=https://graph.facebook.com/v21.0

# -------- OpenTelemetry --------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=erp-backend
OTEL_SAMPLING_RATE=0.1

# -------- Grafana --------
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_pass

# -------- Rate Limiting --------
API_RATE_LIMIT_RPS=100
LOGIN_RATE_LIMIT_RPM=5
AI_RATE_LIMIT_RPM=30

# -------- CORS --------
CORS_ALLOWED_ORIGINS=https://erp-school.id,https://admin.erp-school.id

# -------- Logging --------
LOG_LEVEL=info
LOG_FORMAT=json

# -------- Feature Flags --------
FEATURE_AI_ENABLED=true
FEATURE_PAYMENT_GATEWAY=true
FEATURE_WHATSAPP_NOTIFICATIONS=false

# -------- Payment Gateway --------
PAYMENT_GATEWAY_PROVIDER=midtrans
PAYMENT_GATEWAY_SERVER_KEY=your-midtrans-server-key
PAYMENT_GATEWAY_CLIENT_KEY=your-midtrans-client-key
PAYMENT_GATEWAY_MERCHANT_ID=your-merchant-id
PAYMENT_GATEWAY_IS_PRODUCTION=false

# -------- Security --------
CORS_ALLOWED_ORIGINS=https://erp-school.id,https://admin.erp-school.id,https://staging.erp-school.id
ENCRYPTION_KEY=change_me_32_byte_encryption_key
BCRYPT_COST=12

# -------- Multi-Tenancy --------
DEFAULT_SCHOOL_ID=00000000-0000-0000-0000-000000000001

# -------- Monitoring --------
PROMETHEUS_ENV=production
PROMETHEUS_REGION=id-jkt
